#!/bin/bash

this_script="template/script.sh.erb"
log() {
    echo -e "[$(date -Iseconds)][${this_script}] $1"
}

log "Starting main script"

# ============================================================================
# APPTAINER PATHS & IMAGE
# ============================================================================
APPTAINER_BIN="/shared/spack/opt/spack/linux-skylake_avx512/apptainer-1.4.1-tay33zpzokp6tke64nv442eqlajt3fj2/bin/apptainer"
FAST_IMAGE="/shared/images/rstudio_latest.sif"

# Check for GPU
if [ -n "$CUDA_VISIBLE_DEVICES" ] || [ -n "$SLURM_STEP_GPUS" ]; then
  GPU_FLAG="--nv"
  log "GPU resources detected. Enabling --nv flag."
else
  GPU_FLAG=""
  log "No GPU resources detected. Running in CPU mode."
fi

# ============================================================================
# ENVIRONMENT & FAST SCRATCH DIRECTORIES
# ============================================================================
USER_SCRATCH="/scratch/$USER/${SLURM_JOB_ID:-ood}"
mkdir -p "$USER_SCRATCH"

export APPTAINER_SESSIONDIR="$USER_SCRATCH"
export APPTAINER_TMPDIR="$USER_SCRATCH"
export APPTAINER_CACHEDIR="$USER_SCRATCH"
export XDG_RUNTIME_DIR="$USER_SCRATCH"

# Keep the timeouts elevated just in case
export APPTAINER_MOUNT_TIMEOUT=120
export SQUASHFUSE_MOUNT_TIMEOUT=120
export APPTAINER_SQUASHFUSE_TIMEOUT=120

# RStudio requires write access to certain system directories
SING_BIND_LIST=()
SING_BIND_LIST+=("--bind" "$USER_SCRATCH:/tmp")
SING_BIND_LIST+=("--bind" "$USER_SCRATCH:/var/run/rstudio-server")
SING_BIND_LIST+=("--bind" "$USER_SCRATCH:/var/lib/rstudio-server")

# ============================================================================
# EXECUTION: THE "IGNORE FATAL ERRORS" WORKAROUND
# ============================================================================
log "Launching Apptainer. Disabling strict error checking (set +e)..."

# Prevent Slurm/OOD from aborting if Apptainer throws an exit code 255
set +e 

CONTAINER_LOG="$USER_SCRATCH/rstudio_container.log"
log "Routing all container output and errors to: $CONTAINER_LOG"

# Execute Apptainer. 
# -q suppresses normal info messages.
# > "$CONTAINER_LOG" 2>&1 captures the timeout error so it doesn't trigger OOD's kill switch.
# || true forces the Bash script to view this command as a 'success' even if it fails.
"$APPTAINER_BIN" exec -q ${GPU_FLAG} "${SING_BIND_LIST[@]}" "$FAST_IMAGE" ${JOBROOT}/rstudio.script.sh > "$CONTAINER_LOG" 2>&1 || true

log "Apptainer execution block concluded. If the session died, check $CONTAINER_LOG"

# ============================================================================
# CLEANUP
# ============================================================================
rm -rf "$USER_SCRATCH"
log "RStudio session ended and scratch cleaned up"
