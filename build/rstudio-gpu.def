Bootstrap: docker
From: rocker/ml-verse:4.4.1

%post -c /bin/bash

# Install minimal system dependencies to use GPU stat
apt-get update && apt-get install -y \
    python3-pip \
    python3-dev

R_PACKAGES=(
    "torch
    "data.table"
    "xgboost"
    "lightgbm"
    "luz"
)

for package in "${R_PACKAGES[@]}"
do
    Rscript -e "install.packages(\"${package}\", repos=\"https://archive.linux.duke.edu/cran/\", dependencies=TRUE)"
done

# Only for GPU monitoring, less verbose than nvidia-smi
pip3 install --no-cache-dir \
    gpustat
